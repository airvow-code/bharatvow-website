# BharatVow website — production environment variables
# Copy to .env and set values before `npm run build` for Play Store launch.

# REQUIRED for Google Play website compliance — live Play Store listing URL
# Example: https://play.google.com/store/apps/details?id=com.yourcompany.bharatvow
VITE_PLAY_STORE_URL=

# REQUIRED for app identity on Download and Legal Information pages
# Must match the Application ID in Google Play Console
VITE_ANDROID_PACKAGE=

# Optional — default is support@bharatvow.com for all if unset
VITE_SUPPORT_EMAIL=support@bharatvow.com
VITE_PRIVACY_EMAIL=support@bharatvow.com
VITE_GRIEVANCE_EMAIL=support@bharatvow.com

# --- Play Console Data safety checklist (manual audit before submission) ---
# Align Play Console → App content → Data safety with Privacy Policy §2.5–2.6:
# - Phone/SMS: OTP login only (no Google Sign-In)
# - Storage/photos: Status Viewer, document attachments
# - Camera: optional photo capture in-app
# - Location: Place Store map pins only (not navigation)
# - Notifications: NOT collected — in-app reminders only, no push
# - Contacts: NOT collected — names are user-typed entries
# - Microphone: NOT used
# - Firebase / Google Play Billing: disclosed in §2.6
# - Optional cloud backup: user-initiated for premium modules
