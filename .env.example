# BharatVow website — production environment variables
# Copy to .env and set values before `npm run build` for Play Store launch.

# REQUIRED for Google Play website compliance — live Play Store listing URL
# Example: https://play.google.com/store/apps/details?id=com.bharatvow.app
VITE_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.bharatvow.app

# REQUIRED for app identity on Download and Legal Information pages
# Must match the Application ID in Google Play Console
VITE_ANDROID_PACKAGE=com.bharatvow.app

# Optional — default is support@bharatvow.com for all if unset
VITE_SUPPORT_EMAIL=support@bharatvow.com
VITE_PRIVACY_EMAIL=support@bharatvow.com
VITE_GRIEVANCE_EMAIL=support@bharatvow.com

# REQUIRED for Legal Content Service pages (Privacy, Terms, etc.)
# No trailing slash. Example: http://localhost:3000  or  https://api.example.com
VITE_LEGAL_API_BASE_URL=

# --- Play Console Data safety checklist (manual audit before submission) ---
# Align Play Console → App content → Data safety with Privacy Policy §2.5–2.6:
# - Phone/SMS: OTP login only (no Google Sign-In)
# - Contacts: READ/WRITE only when user imports, selects, or saves contacts in-app
# - Camera: user-initiated capture for bills, receipts, documents, profile images
# - Storage/media: user-selected attach/save/browse (Status Viewer, vault attachments)
# - Microphone (RECORD_AUDIO): user-initiated recording only; not background
# - Location: Place Store, event locations — not continuous tracking or navigation
# - Accessibility Service: optional; user-initiated messaging only (Smart Khata, Event Book, Birthdays & Anniversaries, Festival Studio)
# - Vibrate: in-app feedback only
# - Push/FCM: NOT used for promotional push notifications
# - Firebase Auth + Crashlytics + Google Play Billing + Google Maps (Place Store): disclosed in §2.6
# - Optional cloud backup: user-enabled for applicable premium modules
